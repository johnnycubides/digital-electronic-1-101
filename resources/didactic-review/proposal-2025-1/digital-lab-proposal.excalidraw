      "link": null,
      "locked": false,
      "text": "Los estudiantes adquieren habilidades de\nsimulación y de representación para\nsistemas digitales.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "H4mNi1y1Keee9xuDZGVrd",
      "originalText": "Los estudiantes adquieren habilidades de simulación y de representación para sistemas digitales.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "BRdk8ngHcrsjEiR9eyT8_",
      "type": "rectangle",
      "x": 2364.5,
      "y": 1445.5,
      "width": 495,
      "height": 285,
      "angle": 0,

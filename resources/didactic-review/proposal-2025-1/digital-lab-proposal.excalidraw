    {
      "id": "dnDpOMgZoWZUleFza0oC8",
      "type": "text",
      "x": 1004.0916595458984,
      "y": 1230,
      "width": 403.8166809082031,
      "height": 125,
      "angle": 0,
      "strokeColor": "#1e1e1e",

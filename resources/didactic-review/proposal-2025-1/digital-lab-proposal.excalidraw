    },
    {
      "id": "VQ6kCtEAzYFiNp5qTofdm",
      "type": "text",
      "x": 1692.3999938964844,
      "y": 1272,
      "width": 504.20001220703125,
      "height": 150,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b5aV",
      "roundness": null,
      "seed": 433916205,
      "version": 424,
      "versionNonce": 941261037,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1769694804027,
      "link": null,
      "locked": false,
      "text": "Los estudiantes comprenden la representación de\nlos sistemas digitales en los diferentes dominios,\nreconoces un flujo de diseño digital y la importancia\nde desarrollar un pensamiento algorítmico para\nenfrentar situaciones contextualizadas que puedan\nser enfrentadas con sistemas digitales.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "Hl3oYVj2ipccAHhJz5fqD",
      "originalText": "Los estudiantes comprenden la representación de los sistemas digitales en los diferentes dominios, reconoces un flujo de diseño digital y la importancia de desarrollar un pensamiento algorítmico para enfrentar situaciones contextualizadas que puedan ser enfrentadas con sistemas digitales.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "pFECagLR8B8KCxWy5x2OP",
      "type": "text",
      "x": 1940.5,
      "y": 1334.5,
      "width": 8,
      "height": 25,

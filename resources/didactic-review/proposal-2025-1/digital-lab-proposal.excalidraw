    {
      "id": "F5nF0tcnIl3mY_95E86np",
      "type": "text",
      "x": 1009,
      "y": 1473,
      "width": 390.2833251953125,
      "height": 200,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],

    },
    {
      "id": "4DQO8wzCr_ozvpYCJkBFM",
      "type": "rectangle",
      "x": 2949.5,
      "y": 772.5,
      "width": 433.00000000000006,
      "height": 360,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",

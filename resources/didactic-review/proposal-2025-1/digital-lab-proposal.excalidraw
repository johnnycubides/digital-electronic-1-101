        }
      ],
      "updated": 1769697856654,
      "link": null,
      "locked": false
    },
    {
      "id": "K93lPWkbA6CEwwSu9Reb4",
      "type": "text",
      "x": 2960.3999938964844,
      "y": 1289,
      "width": 419.20001220703125,
      "height": 150,
      "angle": 0,
      "strokeColor": "#1e1e1e",

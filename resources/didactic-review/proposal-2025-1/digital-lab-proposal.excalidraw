      "isDeleted": false,
      "boundElements": [],
      "updated": 1769693476849,
      "link": null,
      "locked": false,
      "text": "Los estudiantes adquieren herramientas y\ntecnicas para el acondicionamiento de\nsensores y actuadores a niveles de\nvoltajes de las FPGA que podrán usar en\nel proyecto",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "y3FBnLlyqy9vjp4qllcSB",
      "originalText": "Los estudiantes adquieren herramientas y tecnicas para el acondicionamiento de sensores y actuadores a niveles de voltajes de las FPGA que podrán usar en el proyecto",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {

        }
      ],
      "updated": 1769698225127,
      "link": null,
      "locked": false
    },
    {
      "id": "CM_Fw3qjYnxcbVL7y6VIc",
      "type": "text",
      "x": 2954.5,
      "y": 777.5,
      "width": 422.6833190917969,
      "height": 350,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b5u",
      "roundness": null,
      "seed": 1004806285,
      "version": 2024,
      "versionNonce": 874310189,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1769698252115,
      "link": null,
      "locked": false,
      "text": "A modo de periférico, se realiza la\nimplementación de un controlador para uno\nde los dispositivos enlistados.\nServomotor SG90, Puente H con PWM,\nGenerador de tonos, Reloj de segundos\ncon 2 displays de 7 segmentos, Motor paso\na paso (Stepper).\n> Los estudiantes hacen uso\ndecomparadores, contadores, clocks,\nmultiplexores para implementar la solución.\n> Para evaluar el aprendizaje, los\nestudiantes realizarán una presentación de\nlos artefactos implementados\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "middle",
      "containerId": "4DQO8wzCr_ozvpYCJkBFM",
      "originalText": "A modo de periférico, se realiza la implementación de un controlador para uno de los dispositivos enlistados.\nServomotor SG90, Puente H con PWM,\nGenerador de tonos, Reloj de segundos con 2 displays de 7 segmentos, Motor paso a paso (Stepper).\n> Los estudiantes hacen uso decomparadores, contadores, clocks, multiplexores para implementar la solución.\n> Para evaluar el aprendizaje, los estudiantes realizarán una presentación de los artefactos implementados\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "ayUERtbUeAo64wM99utLv",
      "type": "rectangle",
      "x": 2955,
      "y": 1272.5,
      "width": 430,
      "height": 182.99999999999994,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,

    {
      "id": "G6eFOo61I7IptdOq8wddO",
      "type": "text",
      "x": 2348.5,
      "y": 833.5,
      "width": 422.3666687011719,
      "height": 275,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
